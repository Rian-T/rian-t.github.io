---
import { profile } from "../data/profile";
---

<section class="intro">
  <div class="portrait-frame">
    <img src="/assets/avatar.jpeg" alt={profile.name} />
  </div>

  <div class="intro-copy">
    <h1>{profile.name}</h1>
    <p class="intro-meta">{profile.role} · {profile.affiliation}</p>
    <p class="bio">{profile.bio}</p>
    <ul class="link-row" aria-label="Profile links">
      {profile.links.map((link) => (
        <li>
          <a 
            href={link.href} 
            data-email={link.isEmail ? "true" : undefined}
            class={link.isEmail ? "email-link" : ""}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  // Simple email obfuscation to prevent bot scraping
  function setupEmail() {
    const emailLinks = document.querySelectorAll('.email-link');
    const u = "rian.touchent";
    const d = "inria.fr";
    
    emailLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        (link as HTMLAnchorElement).href = `mailto:${u}@${d}`;
      });
      // Also set it on hover for better UX
      link.addEventListener('mouseenter', () => {
        (link as HTMLAnchorElement).href = `mailto:${u}@${d}`;
      });
    });
  }

  setupEmail();
  document.addEventListener('astro:after-swap', setupEmail);
</script>
