---
import { profile } from "../data/profile";
---

<section class="intro">
  <div class="portrait-frame">
    <img src="/assets/avatar.jpeg" alt={profile.name} />
  </div>

  <div class="intro-copy">
    <h1>{profile.name}</h1>
    <p class="intro-meta">{profile.role} · {profile.affiliation}</p>
    <p class="bio">{profile.bio}</p>
    
    {profile.stats && (
      <div class="academic-stats">
        <span><strong>{profile.stats.citations}</strong> citations</span>
        <span><strong>{profile.stats.hIndex}</strong> h-index</span>
        <span><strong>{profile.stats.i10Index}</strong> i10-index</span>
      </div>
    )}

    <ul class="link-row" aria-label="Profile links">
      {profile.links.map((link) => (
        <li>
          <a 
            href={link.href} 
            data-email={link.isEmail ? "true" : undefined}
            class={`${link.isEmail ? "email-link" : ""} ${link.label === "CV" ? "cv-link" : ""}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .cv-link {
    display: none !important;
  }
  .academic-stats {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
  }
  .academic-stats strong {
    color: var(--ink);
    font-size: 13px;
  }
</style>

<script>
  // Simple email obfuscation to prevent bot scraping
  function setupEmail() {
    const emailLinks = document.querySelectorAll('.email-link');
    const u = "rian.touchent";
    const d = "inria.fr";
    
    emailLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        (link as HTMLAnchorElement).href = `mailto:${u}@${d}`;
      });
      // Also set it on hover for better UX
      link.addEventListener('mouseenter', () => {
        (link as HTMLAnchorElement).href = `mailto:${u}@${d}`;
      });
    });
  }

  setupEmail();
  document.addEventListener('astro:after-swap', setupEmail);
</script>
